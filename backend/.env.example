# backend/.env.example
PORT=3001
MONGO_URI=mongodb://localhost:27017/loginapp_db
JWT_SECRET=replace_with_a_long_random_secret
VAPID_PUBLIC_KEY=replace_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_your_vapid_private_key

# Focus NFe (NFSe) - homologacao primeiro
NF_PROVIDER=focus
NF_ENV=homolog
FOCUS_TOKEN_HOMOLOG=replace_with_your_homolog_token
FOCUS_BASE_URL_HOMOLOG=https://homologacao.focusnfe.com.br/v2

# Opcional para producao futura
FOCUS_TOKEN_PRODUCAO=
FOCUS_BASE_URL_PRODUCAO=https://api.focusnfe.com.br/v2

# Regras fiscais minimas (ajustar com contador/fiscal)
FOCUS_NFSE_SERVICE_CODE=0701
FOCUS_NFSE_CITY_SERVICE_CODE=0701
FOCUS_NFSE_ISS_ALIQUOTA=5

# Opcional: e-mail padrao do tomador quando nao houver no cadastro
FOCUS_NFSE_DEFAULT_TAKER_EMAIL=
